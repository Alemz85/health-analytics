# Cross-tool agent skills mirror (redundant copy of .claude/skills for non-Claude
# agents; regenerable, so it stays local). AGENTS.md itself is a symlink to
# CLAUDE.md and IS tracked, so any agent gets the same canonical instructions.
.agents/

# Local brainstorming mockups and browser interaction state
.superpowers/

# Knowledge library — separate private repo (github.com/owner/health-knowledge)
knowledge/

# Personal RunKeeper export dumps (raw GPS traces — imported via
# scripts/import_runkeeper.py, never committed). Matches the export folder's
# name and any copy placed under data/.
*runkeeper-data-export*/
/data/runkeeper/
