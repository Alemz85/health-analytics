# Supabase project URL — Supabase dashboard → Project Settings → API
SUPABASE_URL=

# Service-role key (full DB access; server-side only, never ship to a client)
SUPABASE_SERVICE_KEY=

# Shared secret for the ingest Edge Function (32+ random chars).
# Generate with: openssl rand -hex 32
# Must match the INGEST_TOKEN secret set on the deployed function.
INGEST_TOKEN=
